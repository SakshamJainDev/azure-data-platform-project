				"userProperties": [],
				"typeProperties": {
					"method": "POST",
					"url": "https://prod-02.australiaeast.logic.azure.com:443/workflows/096801f6885f4b159adff5306c8677ae/triggers/When_an_HTTP_request_is_received/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2FWhen_an_HTTP_request_is_received%2Frun&sv=1.0&sig=mVmBQVPejCE9euSa3bdjNHFIgHEwoMQ8EVmq35uUGXw",
					"body": {
						"value": "{\n    \"pipelineName\": \"@{pipeline().Pipeline}\",\n    \"status\":\"Succeeded\",\n    \"runId\":\"@{pipeline().RunID}\",\n    \"time\": \"@{utcNow()}\"\n}",
						"type": "Expression"
					}
				}
			},
