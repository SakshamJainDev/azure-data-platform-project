								{
									"referenceName": "DelimitedText1",
									"type": "DatasetReference",
									"parameters": {
										"containerName": "landing",
										"fileName": {
											"value": "@item().name",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "DelimitedText1",
									"type": "DatasetReference",
									"parameters": {
										"containerName": "bronze",
										"fileName": {
											"value": "@item().name",
											"type": "Expression"
										}
									}
								}
							]
